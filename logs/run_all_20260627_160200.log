STEP: 05a_bench_baseline
CMD:  bash -c 
    source vllm_venv/bin/activate
    kill_vllm_local() {
        pkill -f 'vllm serve' 2>/dev/null || true
        local deadline=$(( SECONDS + 30 ))
        while lsof -i :8001 -sTCP:LISTEN &>/dev/null; do
            (( SECONDS > deadline )) && break; sleep 2
        done
    }
    kill_vllm_local
